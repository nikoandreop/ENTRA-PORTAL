FROM node:20-alpine

RUN apk add --no-cache tini

WORKDIR /app

COPY package.json ./
COPY src/shared/package.json src/shared/
COPY src/agent/package.json src/agent/

RUN npm install --workspace=src/shared --workspace=src/agent --ignore-scripts

COPY src/shared/ src/shared/
COPY src/agent/ src/agent/

RUN npm run build --workspace=src/shared && \
    npm run build --workspace=src/agent && \
    rm -rf /root/.npm /tmp/*

ENTRYPOINT ["tini", "--"]
CMD ["node", "src/agent/dist/index.js"]
