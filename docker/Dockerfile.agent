FROM node:20-alpine AS builder

WORKDIR /app

COPY package.json ./
COPY src/shared/package.json src/shared/
COPY src/agent/package.json src/agent/

RUN npm install --workspace=src/shared --workspace=src/agent --ignore-scripts

COPY src/shared/ src/shared/
COPY src/agent/ src/agent/

RUN npm run build --workspace=src/shared && \
    npm run build --workspace=src/agent

FROM node:20-alpine AS runner

RUN apk add --no-cache tini && \
    addgroup -g 1001 -S entra && \
    adduser -S entra -u 1001

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/src/shared/dist ./src/shared/dist
COPY --from=builder /app/src/shared/package.json ./src/shared/
COPY --from=builder /app/src/agent/dist ./src/agent/dist
COPY --from=builder /app/src/agent/package.json ./src/agent/
COPY --from=builder /app/src/agent/node_modules ./src/agent/node_modules

USER entra

ENTRYPOINT ["tini", "--"]
CMD ["node", "src/agent/dist/index.js"]
