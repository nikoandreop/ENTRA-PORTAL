# Entra Portal Configuration
# Copy this file to .env and update the values

# === SECURITY - CHANGE THESE IN PRODUCTION ===
JWT_SECRET=generate-a-64-character-random-string-here
AGENT_JWT_SECRET=generate-another-64-character-random-string
ENCRYPTION_KEY=generate-a-32-character-encryption-key

# Default admin password (only used on first startup)
DEFAULT_ADMIN_PASSWORD=EntraPortal!2024

# === PostgreSQL Database ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=entra_portal
DB_USER=entra
DB_PASSWORD=entra_dev_password
DB_POOL_MAX=20
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# === API Server ===
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# === Microsoft SSO (Entra ID OIDC for dashboard login) ===
# Create an App Registration in your MSP's Entra ID tenant:
#   - Redirect URI: http://localhost:5173/auth/callback (dev) or https://portal.example.com/auth/callback (prod)
#   - Supported account types: "Accounts in any organizational directory" for multi-tenant MSP
#   - API Permissions: openid, profile, email
# SSO_TENANT_ID=common
# SSO_CLIENT_ID=your-sso-app-registration-client-id
# SSO_CLIENT_SECRET=your-sso-client-secret
# SSO_REDIRECT_URI=http://localhost:5173/auth/callback

# === Demo Tenant (optional - for development) ===
# DEMO_GRAPH_TENANT_ID=your-azure-tenant-id
# DEMO_GRAPH_CLIENT_ID=your-app-registration-client-id
# DEMO_GRAPH_CLIENT_SECRET=your-client-secret

# === Integration Tests (optional) ===
# INTEGRATION_GRAPH_TENANT_ID=your-test-tenant-id
# INTEGRATION_GRAPH_CLIENT_ID=your-test-client-id
# INTEGRATION_GRAPH_CLIENT_SECRET=your-test-client-secret
