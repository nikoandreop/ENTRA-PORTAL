# Entra Portal Configuration
# Copy this file to .env and update the values

# === SECURITY - CHANGE THESE IN PRODUCTION ===
JWT_SECRET=generate-a-64-character-random-string-here
AGENT_JWT_SECRET=generate-another-64-character-random-string
ENCRYPTION_KEY=generate-a-32-character-encryption-key

# Default admin password (only used on first startup)
DEFAULT_ADMIN_PASSWORD=EntraPortal!2024

# === API Server ===
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173
DB_DIR=./data

# === Demo Tenant (optional - for development) ===
# DEMO_GRAPH_TENANT_ID=your-azure-tenant-id
# DEMO_GRAPH_CLIENT_ID=your-app-registration-client-id
# DEMO_GRAPH_CLIENT_SECRET=your-client-secret
