{
  "name": "@entra-portal/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/api/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch --env-file=../../.env server.ts",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "ws": "^8.16.0",
    "pg": "^8.13.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "hpp": "^0.2.3",
    "openid-client": "^5.6.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/ws": "^8.5.10",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "@types/hpp": "^0.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
